# Recommended for most uses (not used)
# DATABASE_URL=

# For uses requiring a connection without pgbouncer (not used)
# DATABASE_URL_UNPOOLED=

# Parameters for constructing your own connection string (not used)
# PGHOST=
# PGHOST_UNPOOLED=
# PGUSER=
# PGDATABASE=
# PGPASSWORD=

# Parameters for Vercel Postgres Templates
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=neondb
POSTGRES_URL_NO_SSL=
POSTGRES_PRISMA_URL=